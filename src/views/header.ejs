<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %></title>
  <link rel="stylesheet" href="/public/style.css" />
</head>
<body>
<div class="bg-orb orb1"></div><div class="bg-orb orb2"></div>
<div class="shell">
  <header class="topbar glass">
    <div class="brand">🎬 Fluent Cinema</div>
    <% if (user) { %>
      <nav class="nav">
        <a href="/dashboard">Dashboard</a>
        <% if (user.Role === 'admin' || user.Role === 'staff') { %>
          <a href="/movies">Movies</a>
          <a href="/showtimes">Showtimes</a>
          <a href="/foods">Food & Combo</a>
        <% } %>
        <% if (user.Role === 'admin') { %>
          <a href="/promotions">Promotions</a>
          <a href="/users">Users</a>
        <% } %>
        <% if (user.Role === 'customer') { %>
          <a href="/booking">Đặt vé</a>
          <a href="/my-bookings">Vé của tôi</a>
        <% } %>
      </nav>
      <div class="userbox">Xin chào, <%= user.Fullname %> (<%= user.Role %>) • <a href="/logout">Đăng xuất</a></div>
    <% } %>
  </header>
  <main class="page fade-up">
