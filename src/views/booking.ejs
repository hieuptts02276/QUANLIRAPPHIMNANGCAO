<%- include('header', { title: 'Đặt vé', user }) %>
<section class="card glass">
  <h1>Đặt vé xem phim</h1>
  <form method="get" class="inline-form">
    <label>Chọn suất chiếu
      <select name="showtime" onchange="this.form.submit()">
        <% showtimes.forEach(s => { %>
          <option value="<%= s.ShowtimeID %>" <%= s.ShowtimeID === selectedShowtimeId ? 'selected' : '' %>>
            <%= s.Title %> | <%= s.RoomName %> | <%= s.StartTime %> | <%= Number(s.Price).toLocaleString('vi-VN') %> đ
          </option>
        <% }) %>
      </select>
    </label>
  </form>

  <form method="post" class="grid-form">
    <input type="hidden" name="showtimeId" value="<%= selectedShowtimeId %>" />
    <label>Chọn ghế (nhiều ghế)
      <div class="seat-grid">
        <% seats.forEach(s => { %>
          <label class="seat <%= s.Status %>">
            <input type="checkbox" name="seatIds" value="<%= s.ShowtimeSeatID %>" <%= s.Status !== 'available' ? 'disabled' : '' %> />
            <span><%= s.SeatNumber %></span>
          </label>
        <% }) %>
      </div>
    </label>

    <div class="two-col">
      <label>Food
        <select name="foodId"><option value="">Không</option><% foods.forEach(f => { %><option value="<%= f.FoodID %>"><%= f.FoodName %> - <%= Number(f.Price).toLocaleString('vi-VN') %> đ</option><% }) %></select>
      </label>
      <label>Số lượng food<input type="number" min="0" name="foodQty" value="0"/></label>
      <label>Combo
        <select name="comboId"><option value="">Không</option><% combos.forEach(c => { %><option value="<%= c.ComboID %>"><%= c.ComboName %> - <%= Number(c.Price).toLocaleString('vi-VN') %> đ</option><% }) %></select>
      </label>
      <label>Số lượng combo<input type="number" min="0" name="comboQty" value="0"/></label>
    </div>

    <label>Phương thức thanh toán
      <select name="paymentMethod"><option value="cash">Tiền mặt</option><option value="banking">Chuyển khoản</option><option value="card">Thẻ</option></select>
    </label>
    <button type="submit">Xác nhận đặt vé & thanh toán</button>
  </form>
</section>
<%- include('footer') %>
